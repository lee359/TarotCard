rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    match /admins/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /tarotCards/{cardId} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.number is string
        && request.resource.data.name is string
        && request.resource.data.english is string
        && request.resource.data.symbol is string
        && request.resource.data.keywords is string
        && request.resource.data.meaning is string;
      allow delete: if isAdmin();
    }

    match /siteStats/visitors {
      allow read: if isAdmin();
      allow create: if request.resource.data.keys().hasOnly(['count', 'lastVisitedAt'])
        && request.resource.data.count == 1
        && request.resource.data.lastVisitedAt == request.time;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['count', 'lastVisitedAt'])
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.lastVisitedAt == request.time;
      allow delete: if false;
    }

    match /siteStats/topicSelections {
      allow read: if isAdmin();
      allow create: if request.resource.data.keys()
          .hasOnly(['love', 'career', 'self', 'daily', 'lastCompletedAt'])
        && request.resource.data.love is int
        && request.resource.data.career is int
        && request.resource.data.self is int
        && request.resource.data.daily is int
        && request.resource.data.love >= 0
        && request.resource.data.career >= 0
        && request.resource.data.self >= 0
        && request.resource.data.daily >= 0
        && request.resource.data.love
          + request.resource.data.career
          + request.resource.data.self
          + request.resource.data.daily == 1
        && request.resource.data.lastCompletedAt == request.time;
      allow update: if request.resource.data.keys()
          .hasOnly(['love', 'career', 'self', 'daily', 'lastCompletedAt'])
        && request.resource.data.love is int
        && request.resource.data.career is int
        && request.resource.data.self is int
        && request.resource.data.daily is int
        && request.resource.data.love >= resource.data.love
        && request.resource.data.career >= resource.data.career
        && request.resource.data.self >= resource.data.self
        && request.resource.data.daily >= resource.data.daily
        && request.resource.data.love
          + request.resource.data.career
          + request.resource.data.self
          + request.resource.data.daily
          == resource.data.love
          + resource.data.career
          + resource.data.self
          + resource.data.daily + 1
        && request.resource.data.lastCompletedAt == request.time;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
